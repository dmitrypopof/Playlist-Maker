<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--    Основной экран:-->
    <style name="ActivityScreenMain.Background">
        <item name="android:background">@color/blue_cornflower</item>
    </style>

    <style name="ActivityScreenMain" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">25</item>
        <item name="backgroundTint">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">normal</item>
        <item name="fontFamily">@font/ys_display_medium</item>
        <item name="cornerRadius">16dp</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">10dp</item>
        <item name="iconTint">@color/black_liquorice</item>
    </style>

    <!--    Экран Настройки:-->
    <style name="ActivityScreenSetting" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:textColor">@color/black_liquorice</item>
        <item name="android:textSize">16sp</item>
        <item name="fontFamily">@font/ys_display_regular</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center_vertical</item>

    </style>
    <style name="ActivityScreenMain.Background.Setting">
        <item name="android:background">@color/white</item>
    </style>

    <style name="ActivityScreenMain.Background.Setting.Toolbar" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:backgroundTint">@color/white</item>
        <item name="iconTint">@color/black_liquorice</item>
    </style>


    <style name="DarkLightIcon" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:backgroundTint">@color/white</item>
        <item name="iconTint">@color/black_liquorice</item>
    </style>

    <!--    Экран Поиск:-->
    <style name="ActivitySearchHead" parent="Widget.MaterialComponents.Button.UnelevatedButton">
    <item name="android:textColor">@color/black_liquorice</item>
    <item name="android:textSize">22sp</item>
    <item name="fontFamily">@font/ys_display_medium</item>
    <item name="android:textAllCaps">false</item>
    <item name="android:gravity">center_vertical</item>
    </style>>

    <style name="SearchEditTextStyle" parent="Widget.AppCompat.EditText">
        <item name="android:drawableTint">@color/YP_Text_Gray</item>
        <item name="android:textColorHint">@color/YP_Text_Gray</item>
        <item name="android:textColor">@color/YP_Black</item>
        <item name="drawableTint">@color/YP_Text_Gray</item>
    </style>
    <style name="ClearIconStyle">
        <item name="tint">@color/YP_Text_Gray</item>
    </style>

</resources>