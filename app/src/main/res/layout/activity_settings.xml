<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/back_button"
        style="?android:attr/borderlessButtonStyle"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="start"
        android:textColor="@color/black"
        app:iconGravity="textStart"
        app:iconTint="@color/black"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="@string/textButtonSetting" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:layout_marginTop="24dp"
            style="@style/ButtonSetting"
            android:checked="true"
            android:gravity="center_vertical"
            android:text="@string/setScreen_darkTheme" />
    </FrameLayout>

    <com.google.android.material.textview.MaterialTextView
        style="@style/ButtonSetting"
        android:drawableEnd="@drawable/ic_button_share"
        android:text="@string/setScreen_shareApp" />

    <com.google.android.material.textview.MaterialTextView
        style="@style/ButtonSetting"
        android:drawableEnd="@drawable/ic_button_write_support"
        android:text="@string/setScreen_writeSupport" />

    <com.google.android.material.textview.MaterialTextView
        style="@style/ButtonSetting"
        android:drawableEnd="@drawable/ic_button_arrow_forward"
        android:text="@string/setScreen_userAgreement" />

</LinearLayout>