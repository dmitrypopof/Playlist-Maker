<?xml version="1.0" encoding="utf-8"?>
<resources>
<!--    Основной экран:-->
    <style name="ActivityScreenMain.Background">
        <item name="android:background">@color/black_liquorice</item>
    </style>

<!--    Экран Настройки:-->
    <style name="ActivityScreenSetting" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="fontFamily">@font/ys_display_regular</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center_vertical</item>

        <item name="drawableTint">@color/white</item>
    </style>

    <style name="ActivityScreenMain.Background.Setting">
        <item name="android:background">@color/black_liquorice</item>
    </style>

    <style name="ActivityScreenMain.Background.Setting.Toolbar" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:backgroundTint">@color/black_liquorice</item>
        <item name="iconTint">@color/white</item>
        <item name="android:textColor">@color/white</item>
    </style>


    <style name="DarkLightIcon" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:backgroundTint">@color/black_liquorice</item>
        <item name="iconTint">@color/white</item>
    </style>

    <style name="DarkLightSwitch">
        <item name="thumbTint">@color/blue_cornflower</item>
        <item name="trackTint">@color/blue_cornflower_dark</item>
    </style>


    <!--    Экран Поиск:-->
    <style name="ActivitySearchHead" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">22sp</item>
        <item name="fontFamily">@font/ys_display_medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="SearchEditTextStyle" parent="Widget.AppCompat.EditText">
        <item name="android:tint">@color/white</item>
        <item name="android:textColorHint">@color/YP_Black</item>
        <item name="android:textColor">@color/YP_Black</item>
        <item name="drawableTint">@color/YP_Black</item>
    </style>
    <style name="ClearIconStyle">
        <item name="tint">@color/YP_Black</item>
    </style>
</resources>